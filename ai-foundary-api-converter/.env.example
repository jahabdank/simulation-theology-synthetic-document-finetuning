# ============================================================
# Azure AI Foundry — Model Endpoint Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Each model deployment on Azure AI Foundry has its own
# endpoint URL and API key. Create one entry per model.
# ============================================================

# --- Claude Opus 4.6 (Anthropic) ---
AZURE_ENDPOINT_CLAUDE_OPUS=https://your-resource.services.ai.azure.com/models
AZURE_API_KEY_CLAUDE_OPUS=your-api-key-here

# --- GPT-5.3 Codex (OpenAI) ---
AZURE_ENDPOINT_GPT53_CODEX=https://your-resource.openai.azure.com/
AZURE_API_KEY_GPT53_CODEX=your-api-key-here

# --- GPT-5.2 (OpenAI) ---
AZURE_ENDPOINT_GPT52=https://your-resource.openai.azure.com/
AZURE_API_KEY_GPT52=your-api-key-here

# --- Grok-4 (xAI) ---
AZURE_ENDPOINT_GROK4=https://your-resource.services.ai.azure.com/models
AZURE_API_KEY_GROK4=your-api-key-here

# --- Claude Sonnet 4.6 (Anthropic) ---
AZURE_ENDPOINT_CLAUDE_SONNET=https://your-resource.services.ai.azure.com/models
AZURE_API_KEY_CLAUDE_SONNET=your-api-key-here

# --- Mistral Large 3 (Mistral AI) ---
AZURE_ENDPOINT_MISTRAL_LARGE=https://your-resource.services.ai.azure.com/models
AZURE_API_KEY_MISTRAL_LARGE=your-api-key-here
